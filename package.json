{
  "name": "@lewismoten/emoji",
  "version": "4.0.5",
  "description": "list of named emoji unicode values",
  "type": "module",
  "main": "./dist/commonjs/popular.min.cjs",
  "types": "./dist/esm/types/popular.d.mts",
  "module": "./dist/esm/popular.min.js",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/esm/types/popular.d.mts",
      "import": "./dist/esm/popular.min.js",
      "require": "./dist/commonjs/popular.min.cjs"
    },
    "./popular": {
      "types": "./dist/esm/types/popular.d.mts",
      "import": "./dist/esm/popular.min.js",
      "require": "./dist/commonjs/popular.min.cjs"
    },
    "./all": {
      "types": "./dist/esm/types/all.d.mts",
      "import": "./dist/esm/all.min.js",
      "require": "./dist/commonjs/all.min.cjs"
    },
    "./categories/*": {
      "types": "./dist/esm/types/categories/*.d.mts",
      "import": "./dist/esm/categories/*.min.js",
      "require": "./dist/commonjs/categories/*.min.cjs"
    },
    "./variations/*": {
      "types": "./dist/esm/types/variations/*.d.mts",
      "import": "./dist/esm/variations/*.min.js",
      "require": "./dist/commonjs/variations/*.min.cjs"
    },
    "./manifest": "./manifest.json",
    "./manifest.json": "./manifest.json",
    "./versions/*": "./versions/*.json",
    "./proposed/*": "./proposed/*.json",
    "./development/*": {
      "types": "./dist/esm/types/*.d.mts",
      "import": "./dist/esm/*.js",
      "require": "./dist/commonjs/*.cjs"
    }
  },
  "scripts": {
    "clean": "rm -rf build && rm -rf dist",
    "generate": "node ./scripts/generate-library.mjs",
    "build": "npm run clean && npm run generate && tsc",
    "bundle": "npm run build && node ./scripts/generate-browser.mjs && npx rollup -c ./build/rollup.config.js --silent",
    "prepublishOnly": "npm run bundle",
    "start": "vite",
    "test": "npm run bundle && node ./build/scripts/test.mjs",
    "unicode": "node ./scripts/update-unicode.mjs",
    "unicode:proposed": "node ./scripts/download-proposed-unicode.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lewismoten/emoji.git"
  },
  "keywords": [
    "emoji",
    "unicode",
    "icons",
    "emoticons",
    "emote"
  ],
  "author": "Lewis Moten",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/lewismoten/emoji/issues"
  },
  "homepage": "https://github.com/lewismoten/emoji#readme",
  "devDependencies": {
    "@codejamboree/js-logger": "^2.2.3",
    "@codejamboree/web-request-queue": "^3.2.0",
    "@types/node": "^22.0.0",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-terser": "^1.0.0",
    "rollup": "^4.22.5",
    "rollup-plugin-dts": "^6.1.1",
    "rollup-plugin-license": "^3.7.1",
    "rollup-plugin-typescript2": "^0.36.0",
    "typescript": "^5.6.2",
    "vite": "^8.1.5"
  }
}
